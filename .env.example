# API Configuration
REACT_APP_API_URL=http://localhost:5000/api/getyourstay

# Google OAuth Configuration
# Get your Google Client ID from: https://console.cloud.google.com/
# 1. Create a project or select existing one
# 2. Enable Google+ API
# 3. Go to Credentials > OAuth Client ID > Web application
# 4. Add authorized origins: http://localhost:3000 (for development)
REACT_APP_GOOGLE_CLIENT_ID=your_google_client_id_here
